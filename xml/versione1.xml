    <member ref="I_5_seg3"/>
  </group>
</period>

<period id="I_6" type="periodo">
  <prop id="I_6_p_all" type="full">
    <seg id="I_6_seg1">Delle quali cose le recenti orme della sua fuga e l'ossa nelle altrui terre sepulte e la sparta prole per l'altrui case,</seg>
    <seg id="I_6_seg2">alquante ancora ne fanno chiare.</seg>
    <seg id="I_6_seg3">Se a tutte l'altre iniquità fiorentine fosse possibile il nascondersi agli occhi di Dio,</seg>
    <seg id="I_6_seg4">che veggono tutto,</seg>
    <seg id="I_6_seg5">non dovrebbe questa una bastare</seg>
    <seg id="I_6_seg6">a provocare sopra sé la sua ira?</seg>
    <seg id="I_6_seg7">Certo sì.</seg>
    <seg id="I_6_seg8">Chi in contrario sia esaltato,</seg>
    <seg id="I_6_seg9">giudico</seg>
    <seg id="I_6_seg10">che sia onesto il tacere.</seg>
  </prop>

