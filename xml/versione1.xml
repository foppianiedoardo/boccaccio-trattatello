    <member ref="I_9_seg2"/>
  </group>

  <!-- FINALE I grado: acciò che ... non discordi -->
  <group id="I_9_g_fin" type="subordinata finale" level="I" mode="esplicita" parent="I_9_g_coord_per">
    <member ref="I_9_seg4"/>
    <member ref="I_9_seg6"/>
  </group>

  <!-- RELATIVA II grado: che egli usò nella maggior parte delle sue opere -->
  <group id="I_9_g_rel_I" type="subordinata relativa" level="II" mode="esplicita" parent="I_9_g_fin">
    <member ref="I_9_seg5"/>
  </group>

  <!-- RELATIVA I grado: le quali esso di sé onestamente tacette -->
  <group id="I_9_g_rel_II" type="subordinata relativa" level="I" mode="esplicita" parent="I_9_g_coord_per">
    <member ref="I_9_seg8"/>
  </group>

