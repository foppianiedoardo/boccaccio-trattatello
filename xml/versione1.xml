    <member ref="I_10_seg1"/>
  </group>

  <!-- PRINCIPALE: umilemente priego Colui -->
  <group id="I_10_g_main" type="principale" level="0" mode="esplicita">
    <member ref="I_10_seg2"/>
  </group>

  <!-- RELATIVA I grado: che lui trasse per sì alta scala -->
  <group id="I_10_g_rel_II" type="subordinata relativa" level="I" mode="esplicita" parent="I_10_g_main">
    <member ref="I_10_seg3"/>
  </group>

