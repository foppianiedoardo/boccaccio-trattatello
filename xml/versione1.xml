<period id="I_10" type="periodo">
  <prop id="I_10_p_all" type="full">
    <seg id="I_10_seg1">Il che acciò che non avvenga,</seg>
    <seg id="I_10_seg2">umilemente priego Colui</seg>
    <seg id="I_10_seg3">che lui trasse per sì alta scala</seg>
    <seg id="I_10_seg4">a vedersi,</seg>
    <seg id="I_10_seg5">come sappiamo,</seg>
    <seg id="I_10_seg6">che al presente aiuti</seg>
    <seg id="I_10_seg7">e guidi lo 'ngegno mio e la debole mano.</seg>
  </prop>

