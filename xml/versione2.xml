  <period id="I_1" type="periodo">
    <prop id="I_1_p_all" type="full">
      <seg id="I_1_seg1"> Solone,</seg>
      <seg id="I_1_seg2"> il cui petto uno umano tempio di divina sapienzia fu reputato,</seg>
      <seg id="I_1_seg3"> era,</seg>
      <seg id="I_1_seg4"> secondo che dicono alcuni,</seg>
      <seg id="I_1_seg5"> spesse volte usato</seg>
      <seg id="I_1_seg6"> di dire ogni republica,</seg>
      <seg id="I_1_seg7"> sì come noi,</seg>
      <seg id="I_1_seg8"> andare</seg>
      <seg id="I_1_seg9"> e stare sopra due piedi;</seg>
    </prop>

    <group id="I_1_g_main" type="principale" level="0" mode="e">
